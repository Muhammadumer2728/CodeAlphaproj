[
  {
    "endpoint": {
      "method": "POST",
      "path": "/api/login",
      "headers": {
        "Content-Type": "application/json"
      }
    },
    "cases": [
      {
        "name": "Base (happy-path)",
        "description": "Successful login with valid credentials",
        "headers": {
          "Content-Type": "application/json",
          "Authorization": "Bearer valid_token"
        },
        "request": "{\"username\":\"validUser\",\"password\":\"validPassword\"}",
        "expectedStatus": 200
      },
      {
        "name": "Missing required field - username",
        "description": "Attempt to login without the username field",
        "headers": {
          "Content-Type": "application/json",
          "Authorization": "Bearer valid_token"
        },
        "request": "{\"password\":\"validPassword\"}",
        "expectedStatus": 400
      },
      {
        "name": "Missing required field - password",
        "description": "Attempt to login without the password field",
        "headers": {
          "Content-Type": "application/json",
          "Authorization": "Bearer valid_token"
        },
        "request": "{\"username\":\"validUser\"}",
        "expectedStatus": 400
      },
      {
        "name": "Invalid data type - username",
        "description": "Send username as a number instead of a string",
        "headers": {
          "Content-Type": "application/json",
          "Authorization": "Bearer valid_token"
        },
        "request": "{\"username\":12345,\"password\":\"validPassword\"}",
        "expectedStatus": 400
      },
      {
        "name": "Invalid data type - password",
        "description": "Send password as a number instead of a string",
        "headers": {
          "Content-Type": "application/json",
          "Authorization": "Bearer valid_token"
        },
        "request": "{\"username\":\"validUser\",\"password\":12345}",
        "expectedStatus": 400
      },
      {
        "name": "Empty payload",
        "description": "Send an empty payload",
        "headers": {
          "Content-Type": "application/json",
          "Authorization": "Bearer valid_token"
        },
        "request": "{}",
        "expectedStatus": 400
      },
      {
        "name": "Invalid auth",
        "description": "Tamper with the Authorization header",
        "headers": {
          "Content-Type": "application/json",
          "Authorization": "Bearer invalid_token"
        },
        "request": "{\"username\":\"validUser\",\"password\":\"validPassword\"}",
        "expectedStatus": 400
      },
      {
        "name": "Malformed JSON",
        "description": "Send malformed JSON string",
        "headers": {
          "Content-Type": "application/json",
          "Authorization": "Bearer valid_token"
        },
        "request": "{\"username\":\"validUser\",\"password\":\"validPassword\"",
        "expectedStatus": 400
      },
      {
        "name": "Large payload",
        "description": "Send a very large string as username",
        "headers": {
          "Content-Type": "application/json",
          "Authorization": "Bearer valid_token"
        },
        "request": "{\"username\":\""
      }
    ]
  }
]
